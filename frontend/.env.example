# ============================================================================
# Frontend Environment Variables (EXAMPLE)
# ============================================================================
# 
# This is a template file for the React frontend .env configuration.
# 
# Copy this file to create your actual environment file:
#   cp .env.example .env
# 
# Then update with your actual values.
# 
# IMPORTANT: .env is in .gitignore - do NOT commit it!
# ============================================================================

# ============================================================================
# API Configuration
# ============================================================================

# Backend API URL
# In production, this is typically handled by Nginx proxy
# For local development, point to your backend server
VITE_API_URL=http://localhost:3000/api

# Alternative for production (if not using proxy)
# VITE_API_URL=https://api.example.com/api

# ============================================================================
# NOTES FOR STUDENTS
# ============================================================================
# 
# 1. Vite Environment Variables:
#    - Must start with VITE_ prefix to be exposed to client
#    - Access in code: import.meta.env.VITE_API_URL
#    - Build time variables (not runtime)
# 
# 2. In this project:
#    - Frontend uses relative URLs (/api/*)
#    - Nginx proxies /api/* to backend server
#    - No .env needed in production setup
#    - Only needed for local development
# 
# 3. Local Development Setup:
#    - Create .env in frontend/ directory
#    - Set VITE_API_URL to your local backend
#    - Run: npm run dev
#    - Update src/api.js if needed
# 
# 4. Production Build:
#    - Uses Nginx proxy configuration
#    - No environment variables needed
#    - All API calls go through /api/* path
# 
# ============================================================================
