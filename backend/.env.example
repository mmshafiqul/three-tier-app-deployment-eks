# ============================================================================
# Backend Application Environment Variables (EXAMPLE)
# ============================================================================
# 
# This is a template file for the Node.js backend .env configuration.
# 
# Copy this file to create your actual environment file:
#   cp .env.example .env
# 
# Then update with your actual values.
# 
# IMPORTANT: .env is in .gitignore - do NOT commit it!
# ============================================================================

# ============================================================================
# Database Configuration
# ============================================================================

# Full PostgreSQL connection string
DATABASE_URL=postgresql://bmi_user:your-password@database-host:5432/bmi_db

# Individual database connection parameters
DB_HOST=database-host-or-ip          # Database server hostname or IP
DB_PORT=5432                         # PostgreSQL port (default: 5432)
DB_NAME=bmi_db                       # Database name
DB_USER=bmi_user                     # Database username
DB_PASSWORD=your-secure-password     # Database password

# ============================================================================
# Server Configuration
# ============================================================================

# Port the backend API server will listen on
PORT=3000

# Environment mode: development, production, or test
NODE_ENV=production

# ============================================================================
# CORS Configuration
# ============================================================================

# Frontend URL for CORS (where requests will come from)
FRONTEND_URL=https://bmi.example.com

# CORS origin setting (* for all, or specific domain)
CORS_ORIGIN=*

# ============================================================================
# NOTES FOR STUDENTS
# ============================================================================
# 
# 1. In manual deployment:
#    - SSH to backend server
#    - Navigate to /home/ubuntu/app/backend/
#    - Create .env file with actual values
# 
# 2. In Terraform deployment:
#    - The init script automatically creates .env
#    - Values come from Terraform variables
#    - No manual .env creation needed
# 
# 3. Security:
#    - Never commit .env to Git
#    - Use strong passwords
#    - For production, consider AWS Secrets Manager
#    - Restrict file permissions: chmod 600 .env
# 
# 4. Testing connection:
#    node -e "const { Pool } = require('pg'); \
#             const pool = new Pool({ connectionString: process.env.DATABASE_URL }); \
#             pool.query('SELECT NOW()', (err, res) => { \
#               console.log(err ? err : res.rows[0]); \
#               pool.end(); \
#             });"
# 
# ============================================================================